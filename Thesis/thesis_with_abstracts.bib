@INPROCEEDINGS{Hobson1991,
	author = {Alan J. Hobson and Adam N. Mamelak and Jeffrey P. Sutton},
	title = {Models Wanted: Must Fit Dimensions of Sleep and Dreaming},
	booktitle = {NIPS},
	year = {1991},
	editor = {John E. Moody and Stephen Jose Hanson and Richard Lippmann},
	publisher = {Morgan Kaufmann},
	abstract = {During waking and sleep, the brain and mind undergo a tightly linked
	and precisely specified set of changes in state. At the level of
	neurons, this process has been modeled by variations of Volterra-lotka
	equations for cyclic fluctuations of brainstem cell populations.
	However, neural network models based upon rapidly developed knowledge
	of the specific population connectivities and their differential
	responses to drugs have not yet been developed. Furthermore, only
	the most preliminary attempts have been made to model across states.
	Some of our own attempts to link rapid eye movement (REM) sleep neurophysiology
	and dream cognition using neural network approaches are summarized
	in this paper.},
	bibsource = {DBLP, http://dblp.uni-trier.de},
	isbn = {1-55860-222-4},
	journal = {Advances in Neural Information Processing Systems 4, [NIPS Conference,
	Denver, Colorado, USA, December 2-5, 1991]},
	keywords = {SLEEP Neural Network Model},
	owner = {Simon},
	timestamp = {2007.06.25}
}

@ARTICLE{Hobson2005,
	author = {Hobson, J. Allan},
	title = {Sleep is of the brain, by the brain and for the brain},
	journal = {Nature},
	year = {2005},
	volume = {437},
	pages = {1254--1256},
	number = {7063},
	month = oct,
	abstract = {Sleep is a widespread biological phenomenon, and its scientific study
	is proceeding at multiple levels at the same time. Marked progress
	is being made in answering three fundamental questions: what is sleep,
	what are its mechanisms and what are its functions? The most salient
	answers to these questions have resulted from applying new techniques
	from basic and applied neuroscience research. The study of sleep
	is also shedding light on our understanding of consciousness, which
	undergoes alteration in parallel with sleep-induced changes in the
	brain.},
	comment = {Variation in sleep does not show that sleep has no function merely
	that the brain might be able to find many ways to solve the same
	problem. Animals sleep if they can afford to. Most of sleep is not
	just from that day },
