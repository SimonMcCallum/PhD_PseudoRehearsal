@ARTICLE{Stickgold2005a,
	author = {Stickgold, R. and Walker, M. P.},
	title = {Memory consolidation and reconsolidation: what is the role of sleep?},
	journal = {Trends In Neurosciences},
	year = {2005},
	volume = {28},
	pages = {408--415},
	number = {8},
	month = aug,
	abstract = {Memory consolidation and reconsolidation reflect molecular, cellular
	and systems-level processes that convert labile memory representations
	into more permanent ones, available for continued reactivation and
	recall over extended periods of time. Here, we discuss the complexities
	of consolidation and reconsolidation, and suggest they should be
	viewed not as all-or-none phenomena, but as a continuing series of
	biological adjustments that enhance both the efficiency and the utility
	of stored memories over time and in response to changing needs of
	the organism. As such, consolidation and reconsolidation might be
	better thought of as memory organization and reorganization. A rapidly
	growing body of evidence suggests that many of these processes are
	optimally engaged during sleep.},
