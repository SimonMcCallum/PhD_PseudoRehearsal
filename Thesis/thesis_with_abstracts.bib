@ARTICLE{Mazza1997,
	author = {Mazza, C},
	title = {On the storage capacity of nonlinear neural networks},
	journal = {NEURAL NETWORKS},
	year = {1997},
	volume = {10},
	pages = {593--597},
	number = {4},
	abstract = {We consider the Hopfield associative memory for storing m patterns
	xi' is an element of { - 1, + 1}(n), r = 1,..,m. The weights are
	given by the scalar product model w(ij) = (root m/n)G((1/root m)xi(j)),
	i not equal j, w(ii) = 0, where G:R --> R is some nonlinear function,
	like G(x) = Sgn(x), which is used in hardware implementation of associative
	memories. We give a rigorous lower bound for the memory size of this
	(ANN) by using large deviations estimates. Our main result states
	that retrieval without errors occurs when m(n) --> infinity as n
	--> infinity in such a way that m(n) < (n/2log(n)q(G), where 0 <
	q(G): = E(NG(N))(2)/E(G(N)(2))) less than or equal to 1, N denotes
	a standard normal random variable, and E(.) is the expectation operator.
	(C) 1997 Elsevier Science Ltd.},
	keywords = {MEMORY CAPACITY},
	owner = {Simon},
	timestamp = {2007.06.25}
}

