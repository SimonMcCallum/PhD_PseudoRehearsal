@ARTICLE{Christos1996,
	author = {George A. Christos},
	title = {Investigation of the Crick-Mitchison Reverse-Learning Dream Sleep
	Hypothesis in a Dynamic Setting},
	journal = {Neural Networks},
	year = {1996},
	volume = {9},
	pages = {427-434},
	number = {3},
	abstract = {Crick and Mitchison have proposed that dream sleep involves a reverse-learning
	(or unlearning) mechanism by which the brain eliminates internal
	parasitic modes from memory and avoids the overloading catastrophe.
	We perform stimulations on the Hopfield neural network to test this
	hypothesis. In our dynamical model, the neural network is allowed
	to learn (while awake) and unlearn (while dreaming) in alternate
	cycles, in much the same was as in a biological system. Our results
	show that with the appropriate mix of learning and unlearning (dreaming)
	the neural network can continue to function for ever and ever, avoiding
	the overloading catastrophe. As found in other palimpsest models,
	the dynamic storage capacity in our model is lower in comparison
	to the static model. This would seem to suggest that the function
	of dream sleep may not be primarily concerned with improving the
	storage capacity of the brain as is commonly thought. On the basis
	of this we suggest that dream sleep may be more important as a means
	to gradually forget weak (that is, old, irrelevant and parasitic)
	memories.},
	keywords = {SLEEP Dream Sleep Unlearning REM Sleep Memory Neural Net Hopfield
	Model},
	owner = {Simon},
	pdf = {Christos1996.pdf},
	timestamp = {2007.06.25}
}

