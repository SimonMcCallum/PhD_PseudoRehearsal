                             N 64		//	Number of units in the network
                activationType THRESHOLD  	//	The activation type of the network
                            ON 1  
                           OFF -1
                     maxCycles 4*N
                    relaxation ASYNCRONOUS // SYNCRONOUS or ASYNCRONOUS
                  unitsInRatio 0.1 //	ie 0.1    10%
                          bias FALSE
                   learnTiming ONLINE //BATCH 
              symmetricWeights 0			//TRUE
             weightCappingType NOCAP	//NOCAP , HARDCAP, SOFTCAP
            weightCappingValue 2*N
                   weightDecay off // 
              weightDecayValue 0.1 //10% ie weight*(1-val)
       weightNormalisationType NONORMALISATION 
      weightNormalisationValue 50*N 			// the point at which to normalise
          calcHammingDistRelax on
            calcInitialChanges on
         noiseDuringRelaxation off
             gaussianNoiseType RELATIVE
lenghtOfTimeStableInRelaxation 100
gaussianRelativeRangeForRelaxation 0.1 
gaussianAbsoluteRangeForRelaxation 0.25*N
                  sampleProbOn 0.5 		//This is the proability of a unit being on during sampling
                 gnuplotGraphs off			//TRUE
                    debugLevel 0
                    randomSeed 13
